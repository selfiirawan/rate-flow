<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rate Flow</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Syne:wght@400..800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/styles/styles.css">
    <link rel="stylesheet" href="/styles/background.css">
</head>
<body>
    <canvas id="bg"></canvas>

    <div class="content">
        <h1>Rate Flow</h1>
        <h2>Real-Time Currency Converter</h2>

        <form action="/convert" method="POST">
            <input type="number" name="amount" id="amount" placeholder="Amount" required>

            <!-- FROM CURRENCY -->
            <select name="fromCurrency" id="fromCurrency">
                <option value=""></option>
                <% currencies.forEach(([code, name]) => { %>
                    <option value="<%= code %>" <%= locals.fromCurrency === code ? 'selected' : '' %>><%= code %> - <%= name %></option>
                <% }) %>
            </select>

            <!-- REVERSE BUTTON -->
            <button type="button" id="reverseBtn">🔄</button>

            <!-- TO CURRENCY -->
            <select name="toCurrency" id="toCurrency">
                <option value=""></option>
                <% currencies.forEach(([code, name]) => { %>
                    <option value="<%= code %>" <%= locals.toCurrency === code ? 'selected' : '' %>><%= code %> - <%= name %></option>
                <% }) %>
            </select>

            <!-- CONVERT BUTTON -->
            <button type="submit">Convert</button>


            <!-- RESULT BUTTON -->
            <% if (locals.convertedAmount) { %>
                <h2><%= amount %> <%= fromCurrency %> = <%= convertedAmount %> <%= toCurrency %></h2>
            <% } %>

            <% if (locals.error) { %>
                <p style="color: red;"><%= error %></p>
            <% } %>
        </form>
    </div>

    <!-- Bootstrap starts here -->
    <div class="container col-xl-10 col-xxl-8 px-4 py-5"> 
        <div class="row align-items-center g-lg-5 py-5"> 
            <div class="col-lg-7 text-lg-start"> 
                <h1 class="display-1 fw-bold lh-1 mb-5 title">RATE<br>FLOW</h1> 
                <p class="col-lg-10 fs-5 tag-line">Real-Time Currency Converter</p> 
            </div> 
            <div class="col-md-10 mx-auto col-lg-5"> 
                <form class="p2 p-md-5 border rounded-5 bg-form"> 
                    <p>CONVERT HERE</p>
                    <div class="form-floating mb-3"> 
                        <input type="email" class="form-control" id="floatingInput" placeholder="name@example.com"> 
                        <label for="floatingInput">Email address</label> 
                    </div> 
                    <div class="form-floating mb-3"> 
                        <input type="password" class="form-control" id="floatingPassword" placeholder="Password"> 
                        <label for="floatingPassword">Password</label> 
                    </div> 
                    <div class="checkbox mb-3"> 
                        <label> 
                            <input type="checkbox" value="remember-me"> Remember me
                        </label> 
                    </div> 
                    <button class="w-100 btn btn-lg btn-primary" type="submit">Sign up</button> 
                    <hr class="my-4"> 
                    <small class="text-body-secondary">By clicking Sign up, you agree to the terms of use.</small> 
                </form> 
            </div> 
        </div> 
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="/js/script.js"></script>
    <script src="/js/background.js"></script>
</body>
</html>